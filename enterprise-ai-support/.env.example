# ============================================================
#  Enterprise AI Customer Support Assistant — environment
#  Copy to `.env` and fill in. Never commit the real .env.
# ============================================================

# ---- App ----
APP_NAME="Enterprise AI Support"
ENVIRONMENT=development            # development | production
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000

# ---- Security / JWT ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ---- Database ----
# Dev default is SQLite (no server needed). For prod use PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/support
DATABASE_URL=sqlite:///./data/app.db

# ---- LLM (OpenAI-compatible endpoint) ----
# Works with OpenAI, Groq, Together, vLLM, or local Ollama
# (Ollama: base_url=http://localhost:11434/v1, api_key=ollama)
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# ---- Embeddings ----
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DEVICE=cpu              # cpu | cuda

# ---- Vector store ----
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=support_docs

# ---- RAG tuning ----
CHUNK_SIZE=900
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=8
RERANK_TOP_N=4

# ---- Voice ----
WHISPER_MODEL=base               # tiny | base | small | medium | large

# ---- Frontend ----
BACKEND_URL=http://localhost:8000
